# model training/export artifacts (runtime bundle keeps only .tflite + labels/routing metadata)
assets/tflite/near_nature_app_bundle/**/tflite/tflite_out/
assets/tflite/near_nature_app_bundle/**/tflite/_docker_onnx2tflite.py
assets/tflite/near_nature_app_bundle/**/tflite/export_dummy_input.npy
assets/tflite/near_nature_app_bundle/**/*.onnx
assets/tflite/near_nature_app_bundle/**/*.pt
assets/tflite/near_nature_app_bundle/**/*.pth
assets/tflite/near_nature_app_bundle/**/train.log
assets/tflite/near_nature_app_bundle/**/train.err.log
assets/tflite/near_nature_app_bundle/**/*.log

# trained_v4 training/export artifacts (runtime bundle keeps .tflite + labels/metadata)
assets/tflite/trained_v4/**/tflite/tflite_out/
assets/tflite/trained_v4/**/tflite/_docker_onnx2tflite.py
assets/tflite/trained_v4/**/tflite/export_dummy_input.npy
assets/tflite/trained_v4/**/*.onnx
assets/tflite/trained_v4/**/*.pt
assets/tflite/trained_v4/**/train.log
assets/tflite/trained_v4/**/train.err.log
# Optional export sidecars (runtime uses canonical *.tflite only; keeps APK/repo lean)
assets/tflite/trained_v4/**/*_float32.tflite
assets/tflite/trained_v4/**/*_float16.tflite

# local tooling scratch
supabase/.temp/
build-log.txt
