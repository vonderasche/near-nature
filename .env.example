# Copy to .env for local development. Do not commit .env.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Server-only — for npm run seed:* and verify scripts. Never commit or bundle in the app.
# Supabase Dashboard → Project Settings → API → service_role → Reveal
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Local Supabase (Node / iOS Simulator): http://127.0.0.1:54321
# Android emulator: http://10.0.2.2:54321 (or 127.0.0.1 — app may rewrite via resolveSupabaseUrl)
# Physical device: set EXPO_PUBLIC_SUPABASE_DEV_HOST to your PC LAN IP (ipconfig / ifconfig)
# EXPO_PUBLIC_SUPABASE_DEV_HOST=192.168.1.100
#
# Save identifications to local Supabase (Storage + detections table):
# EXPO_PUBLIC_LOCAL_DETECTIONS=false
# Run sql/ scripts in Supabase Studio (local) — see sql/README.md — then restart Expo.
#
# Android physical device + Metro:
#   Terminal 1: npm run start:dev
#   Terminal 2: npm run android:install   (or npm run android if port 8081 is free)
# USB debugging: scripts/run-android-device.ps1 runs adb reverse tcp:8081 tcp:8081

# On-phone only (no Supabase Storage/DB) — for offline APK testing:
# EXPO_PUBLIC_LOCAL_DETECTIONS=true
# Build: npm run android:device-test-apk  (script sets this flag in .env)

# Slim release APK — only assets/tflite/preview_models/*.tflite bundled (live camera models).
# Specialist genus weights download per region from Supabase.
# Build: npm run android:preview-apk
# EXPO_PUBLIC_SLIM_APK=1

# Gemini — local dev direct API, or Supabase Edge Function when signed in (web fallback)
# EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash

# Set on Supabase (not here): supabase secrets set GEMINI_API_KEY=...
# Optional: supabase secrets set GEMINI_MODEL=gemini-2.0-flash

# Google OAuth — configure in Supabase Dashboard (hosted), not in the mobile app.
# Local Supabase only (supabase/config.toml): GOOGLE_CLIENT_ID= / GOOGLE_CLIENT_SECRET=
# Redirect URLs to allowlist in Supabase: nearnature://auth/callback (+ exp://… in dev). See docs/GOOGLE_SIGN_IN.md

# Legal links on sign-up (optional; defaults to nearnature.app)
# EXPO_PUBLIC_TERMS_URL=https://example.com/terms
# EXPO_PUBLIC_PRIVACY_URL=https://example.com/privacy
