# Copy to `.env` and fill in. Never commit `.env` (it is gitignored).

# Supabase (same project for URL + anon key)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Sign-In — @react-native-google-signin/google-signin + Supabase `signInWithIdToken`
#
# Required on Android + iOS builds:
# • EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID — OAuth client type "Web application" (same Client ID you use in Supabase → Auth → Google).
#
# Android Play Services:
# • Also create an OAuth "Android" client in Google Cloud with package com.vonderasche.near_nature and your app's SHA-1 (android\gradlew.bat signingReport).
# • You may optionally set EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID for your own reference; the native SDK does not require it in configure().
#
# iOS:
# • EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID — OAuth "iOS" client from Google Cloud.

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
