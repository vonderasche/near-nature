# Copy to `.env` before building a release APK (values are baked in at build time).
# Never commit `.env`.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Sign-In (Supabase Auth → Google provider uses the Web client ID)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Optional: iOS Google client when you ship TestFlight
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Species identification: deploy Edge Function `identify-species` and set Supabase secrets:
#   ANTHROPIC_API_KEY, optional ANTHROPIC_MODEL=claude-sonnet-4-6
# Do NOT ship EXPO_PUBLIC_ANTHROPIC_API_KEY in friends APKs (extractable from the bundle).

# Local dev fallback only (direct Anthropic from the app):
# EXPO_PUBLIC_ANTHROPIC_API_KEY=
# EXPO_PUBLIC_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional default state when profile has no state (camera / iNaturalist)
# EXPO_PUBLIC_USER_STATE=FL
