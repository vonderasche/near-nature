# Copy to .env for local development. Do not commit .env.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Local Supabase (Node / iOS Simulator): http://127.0.0.1:54321
# Physical device or Android emulator: app rewrites 127.0.0.1 automatically when possible.
# If you still see "Network request failed", set your PC's LAN IP (ipconfig / ifconfig):
# EXPO_PUBLIC_SUPABASE_DEV_HOST=192.168.1.100

# Claude — local dev direct API, or Supabase Edge Function when signed in
# EXPO_PUBLIC_ANTHROPIC_API_KEY=
# EXPO_PUBLIC_ANTHROPIC_MODEL=claude-sonnet-4-6

# Set on Supabase (not here): supabase secrets set ANTHROPIC_API_KEY=sk-ant-...

# Legal links on sign-up (optional; defaults to nearnature.app)
# EXPO_PUBLIC_TERMS_URL=https://example.com/terms
# EXPO_PUBLIC_PRIVACY_URL=https://example.com/privacy
